<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{A1B2C3D4-5678-9ABC-DEF0-1234567890AB}</ProjectGuid>
        <MainSource>XmlDocExpert.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <ProjectName Condition="'$(ProjectName)'==''">XmlDocExpert</ProjectName>
        <TargetedPlatforms>1048577</TargetedPlatforms>
        <AppType>Library</AppType>
        <FrameworkType>VCL</FrameworkType>
        <ProjectVersion>20.3</ProjectVersion>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win32)'!=''">
        <Cfg_1_Win32>true</Cfg_1_Win32>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win64)'!=''">
        <Cfg_1_Win64>true</Cfg_1_Win64>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win32)'!=''">
        <Cfg_2_Win32>true</Cfg_2_Win32>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win64)'!=''">
        <Cfg_2_Win64>true</Cfg_2_Win64>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'=='true'">
        <SanitizedProjectName>XmlDocExpert</SanitizedProjectName>
        <DCC_E>false</DCC_E>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_ImageBase>00400000</DCC_ImageBase>
        <GenDll>true</GenDll>
        <DCC_Namespace>Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;System;Xml;Data;Datasnap;Web;Soap;$(DCC_Namespace)</DCC_Namespace>
        <VerInfo_Locale>1042</VerInfo_Locale>
        <VerInfo_Keys>CompanyName=;FileDescription=$(MSBuildProjectName);FileVersion=1.0.0.0;InternalName=;LegalCopyright=;LegalTrademarks=;OriginalFilename=;ProgramID=com.embarcadero.$(MSBuildProjectName);ProductName=$(MSBuildProjectName);ProductVersion=1.0.0.0;Comments=</VerInfo_Keys>
        <DCC_UnitSearchPath>..\..\Vendor\DelphiAST\Source;..\..\Vendor\DelphiAST\Source\SimpleParser;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <DCC_DcuOutput>.\$(Platform)\$(Config)</DCC_DcuOutput>
        <UsePackages>true</UsePackages>
        <DCC_UsePackage>rtl;vcl;designide;xmlrtl;vclwinx;vcledge;VclSmp;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win32)'=='true'">
        <DCC_Namespace>Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;$(DCC_Namespace)</DCC_Namespace>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <DCC_UsePackage>rtl;vcl;designide;xmlrtl;vclwinx;vcledge;VclSmp;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win64)'=='true'">
        <DCC_Namespace>Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;$(DCC_Namespace)</DCC_Namespace>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <DCC_UsePackage>rtl;vcl;designide;xmlrtl;vclwinx;vcledge;VclSmp;$(DCC_UsePackage)</DCC_UsePackage>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'=='true'">
        <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'=='true'">
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
        <DCC_RangeChecking>true</DCC_RangeChecking>
        <DCC_IntegerOverflowCheck>true</DCC_IntegerOverflowCheck>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\Core\XmlDoc.Consts.pas"/>
        <DCCReference Include="..\Core\XmlDoc.Model.pas"/>
        <DCCReference Include="..\Core\XmlDoc.CodeGen.pas"/>
        <DCCReference Include="..\Core\XmlDoc.CodeGen.OTA.pas"/>
        <DCCReference Include="..\Core\XmlDoc.Parser.pas"/>
        <DCCReference Include="..\Core\XmlDoc.StubGen.pas"/>
        <DCCReference Include="..\Core\XmlDoc.I18n.pas"/>
        <DCCReference Include="..\Core\XmlDoc.Logger.pas"/>
        <DCCReference Include="..\Core\XmlDoc.ErrorHandler.pas"/>
        <DCCReference Include="..\Core\XmlDoc.ParamDict.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Types.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Scanner.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.BatchParser.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.CrossRef.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Renderer.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Renderer.HTML.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Renderer.MD.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Renderer.CHM.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Renderer.JSON.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.SitePublisher.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.Coverage.pas"/>
        <DCCReference Include="..\HelpGen\XmlDoc.HelpGen.ThemeEngine.pas"/>
        <DCCReference Include="XmlDoc.Plugin.Main.pas"/>
        <DCCReference Include="XmlDoc.Plugin.EditorNotifier.pas"/>
        <DCCReference Include="XmlDoc.Plugin.DocInspector.pas"/>
        <DCCReference Include="XmlDoc.Plugin.Settings.pas"/>
        <DCCReference Include="XmlDoc.Plugin.SettingsDialog.pas">
            <Form>SettingsDialogForm</Form>
        </DCCReference>
        <DCCReference Include="XmlDoc.Plugin.Shortcuts.pas"/>
        <DCCReference Include="XmlDoc.Plugin.BatchGenDialog.pas"/>
        <DCCReference Include="XmlDoc.Plugin.CoverageDialog.pas">
            <Form>CoverageDialogForm</Form>
        </DCCReference>
        <DCCReference Include="XmlDoc.Plugin.QuickDocPreview.pas"/>
        <DCCReference Include="XmlDoc.Plugin.UndocNavigator.pas"/>
        <DCCReference Include="XmlDoc.Plugin.UpdateChecker.pas"/>
        <BuildConfiguration Include="Release">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Library</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">XmlDocExpert.dpr</Source>
                </Source>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
    <Import Project="$(MSBuildProjectName).deployproj" Condition="Exists('$(MSBuildProjectName).deployproj')"/>
</Project>
